msgstr "%{name} declara:"

msgid "Captain of %{name} states:"
msgstr "El capitán de %{name} declara:"

msgid ""
"\"I will accept your surrender and grant you and your troops safe passage "
"for the price of %{price} gold.\""
msgstr ""
"\"Aceptaré tu rendición y concederé salvoconducto a ti y tus tropas por "
"%{price} piezas de oro.\""

